# ─────────────────────────────────────────────────────────────
# Vethis — variáveis de ambiente (12-factor).
# Copie para `.env` e preencha. NUNCA commite o `.env` real.
# Segredos de produção vivem em cofre/secret manager, não aqui.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# API (NestJS)
API_PORT=3333
API_URL=http://localhost:3333

# Banco de dados (Postgres) — serviço privado no Compose
POSTGRES_USER=vethis
POSTGRES_PASSWORD=change-me-in-local-only
POSTGRES_DB=vethis
DATABASE_URL=postgresql://vethis:change-me-in-local-only@localhost:5432/vethis

# Redis (sessões + filas) — serviço privado no Compose
REDIS_URL=redis://localhost:6379

# Sessão / segurança (gerar valores fortes; ex.: `openssl rand -hex 32`)
SESSION_SECRET=replace-with-32-byte-random-hex
COOKIE_DOMAIN=localhost

# Google OIDC (login social)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3333/v1/auth/google/callback

# Pagamentos — port PaymentGateway. Adapter padrão em dev: `fake`.
# Trocar para `asaas` (sandbox) quando integrar. Valores reais só no cofre.
PAYMENT_GATEWAY=fake
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# Vídeo (Vimeo embed privado)
VIMEO_ACCESS_TOKEN=

# IA (opcional) — habilita "Gerar com IA" no backoffice. Sem a chave, o recurso
# fica desativado. Chave real só no cofre/secret manager.
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# Observabilidade (opcional em dev)
SENTRY_DSN=
