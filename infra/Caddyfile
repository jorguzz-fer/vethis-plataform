# Vethis — ingress único (produção).
# Caddy é a ÚNICA porta pública (80/443, TLS automático via Let's Encrypt).
# Todos os serviços de aplicação ficam na rede privada do Compose.
#
# Substituir os domínios pelos seus antes de subir.

vethis.com.br, www.vethis.com.br {
	encode zstd gzip
	reverse_proxy site:3000
}

app.vethis.com.br {
	encode zstd gzip
	reverse_proxy aluno:80
}

admin.vethis.com.br {
	encode zstd gzip
	# Backoffice: recomendado restringir por IP/VPN em produção.
	reverse_proxy backoffice:80
}

api.vethis.com.br {
	encode zstd gzip
	reverse_proxy api:3333
}
