{
  "openapi": "3.1.0",
  "info": {
    "title": "Vethis API",
    "version": "0.1.0",
    "description": "API da plataforma Vethis — educação médica veterinária."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "schemas": {
      "RegisterInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 200
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "LoginInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "PublicUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          },
          "role": {
            "type": "string",
            "enum": [
              "aluno",
              "staff",
              "admin"
            ]
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "role"
        ]
      },
      "AuthUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "aluno",
              "staff",
              "admin"
            ]
          }
        },
        "required": [
          "id",
          "email",
          "role"
        ]
      },
      "Specialty": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "icon": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "slug",
          "name",
          "description",
          "icon"
        ]
      },
      "CourseSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": [
              "string",
              "null"
            ]
          },
          "priceCents": {
            "type": "integer"
          },
          "level": {
            "type": "string",
            "enum": [
              "iniciante",
              "intermediario",
              "avancado"
            ]
          },
          "coverUrl": {
            "type": [
              "string",
              "null"
            ]
          },
          "specialty": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "slug": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "instructor": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "slug": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          }
        },
        "required": [
          "id",
          "slug",
          "title",
          "subtitle",
          "priceCents",
          "level",
          "coverUrl",
          "specialty",
          "instructor"
        ]
      },
      "CourseDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": [
              "string",
              "null"
            ]
          },
          "priceCents": {
            "type": "integer"
          },
          "level": {
            "type": "string",
            "enum": [
              "iniciante",
              "intermediario",
              "avancado"
            ]
          },
          "coverUrl": {
            "type": [
              "string",
              "null"
            ]
          },
          "specialty": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "slug": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "instructor": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "slug": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "modules": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "title": {
                  "type": "string"
                },
                "position": {
                  "type": "integer"
                },
                "lessons": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "title": {
                        "type": "string"
                      },
                      "durationSeconds": {
                        "type": "integer"
                      },
                      "isFree": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "id",
                      "title",
                      "durationSeconds",
                      "isFree"
                    ]
                  }
                }
              },
              "required": [
                "id",
                "title",
                "position",
                "lessons"
              ]
            }
          }
        },
        "required": [
          "id",
          "slug",
          "title",
          "subtitle",
          "priceCents",
          "level",
          "coverUrl",
          "specialty",
          "instructor",
          "description",
          "modules"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/v1/auth/register": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Cadastro de aluno (cria sessão)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicUser"
                }
              }
            }
          }
        }
      }
    },
    "/v1/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Login (cria sessão)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Autenticado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicUser"
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas"
          }
        }
      }
    },
    "/v1/auth/logout": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Encerra a sessão",
        "responses": {
          "204": {
            "description": "Sem conteúdo"
          }
        }
      }
    },
    "/v1/auth/me": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Usuário autenticado",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthUser"
                }
              }
            }
          },
          "401": {
            "description": "Não autenticado"
          }
        }
      }
    },
    "/v1/catalog/specialties": {
      "get": {
        "tags": [
          "catalog"
        ],
        "summary": "Lista especialidades",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Specialty"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/catalog/courses": {
      "get": {
        "tags": [
          "catalog"
        ],
        "summary": "Lista cursos publicados",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": false,
            "name": "specialty",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "iniciante",
                "intermediario",
                "avancado"
              ]
            },
            "required": false,
            "name": "level",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CourseSummary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/catalog/courses/{slug}": {
      "get": {
        "tags": [
          "catalog"
        ],
        "summary": "Detalhe do curso",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "slug",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CourseDetail"
                }
              }
            }
          },
          "404": {
            "description": "Não encontrado"
          }
        }
      }
    }
  },
  "webhooks": {}
}
