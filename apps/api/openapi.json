          },
          "level": {
            "type": "string",
            "enum": [
              "iniciante",
              "intermediario",
              "avancado"
            ]
          },
          "coverUrl": {
            "type": [
              "string",
              "null"
            ]
          },
          "specialty": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "slug": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "instructor": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "slug": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          }
        },
        "required": [
          "id",
          "slug",
          "title",
          "subtitle",
          "priceCents",
          "level",
          "coverUrl",
          "specialty",
          "instructor"
        ]
      },
      "CourseDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
