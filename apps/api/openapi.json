          },
          "role": {
            "type": "string",
            "enum": [
              "aluno",
              "staff",
              "admin"
            ]
          }
        },
        "required": [
          "id",
          "email",
          "role"
        ]
      },
      "Specialty": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
