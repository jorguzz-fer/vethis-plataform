    "parameters": {}
  },
  "paths": {
    "/v1/auth/register": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Cadastro de aluno (cria sessão)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicUser"
                }
              }
            }
          }
        }
      }
    },
    "/v1/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Login (cria sessão)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Autenticado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicUser"
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas"
          }
        }
      }
    },
    "/v1/auth/logout": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Encerra a sessão",
        "responses": {
          "204": {
            "description": "Sem conteúdo"
          }
        }
      }
    },
    "/v1/auth/me": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Usuário autenticado",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthUser"
                }
              }
            }
          },
          "401": {
            "description": "Não autenticado"
          }
        }
      }
    },
    "/v1/catalog/specialties": {
      "get": {
        "tags": [
          "catalog"
        ],
        "summary": "Lista especialidades",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Specialty"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/catalog/courses": {
      "get": {
        "tags": [
          "catalog"
        ],
        "summary": "Lista cursos publicados",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": false,
            "name": "specialty",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "iniciante",
                "intermediario",
                "avancado"
              ]
            },
            "required": false,
            "name": "level",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CourseSummary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/catalog/courses/{slug}": {
      "get": {
        "tags": [
          "catalog"
        ],
        "summary": "Detalhe do curso",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "slug",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CourseDetail"
                }
              }
            }
          },
          "404": {
            "description": "Não encontrado"
          }
        }
      }
    },
    "/v1/me/courses": {
      "get": {
        "tags": [
          "aluno"
        ],
        "summary": "Cursos matriculados do aluno",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EnrolledCourse"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autenticado"
          }
        }
      }
    },
    "/v1/me/courses/{slug}": {
      "get": {
        "tags": [
          "aluno"
        ],
        "summary": "Player do curso (aulas com vídeo; exige matrícula)",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "slug",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CoursePlayer"
                }
              }
            }
          },
          "403": {
            "description": "Não matriculado"
          }
        }
      }
    },
    "/v1/me/lessons/{lessonId}/complete": {
      "post": {
        "tags": [
          "aluno"
        ],
        "summary": "Marca aula como concluída",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "lessonId",
            "in": "path"
          }
        ],
        "responses": {
          "201": {
            "description": "Registrado"
          },
          "403": {
            "description": "Não matriculado"
          }
        }
      }
    },
    "/v1/me/secretaria": {
      "get": {
        "tags": [
          "aluno"
        ],
        "summary": "Solicitações da secretaria do aluno",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SecretariaRequest"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "aluno"
        ],
        "summary": "Abre uma solicitação de secretaria",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSecretariaInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SecretariaRequest"
                }
              }
            }
          }
        }
      }
    },
    "/v1/leads": {
      "post": {
        "tags": [
          "crm"
        ],
        "summary": "Captura pública de lead (site)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLeadInput"
