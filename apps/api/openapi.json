              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "instructor": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "slug": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "modules": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "title": {
                  "type": "string"
                },
                "position": {
                  "type": "integer"
                },
                "lessons": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "title": {
                        "type": "string"
                      },
                      "durationSeconds": {
                        "type": "integer"
                      },
                      "isFree": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "id",
                      "title",
                      "durationSeconds",
                      "isFree"
                    ]
                  }
                }
              },
              "required": [
                "id",
                "title",
                "position",
                "lessons"
              ]
            }
          }
        },
        "required": [
          "id",
          "slug",
          "title",
          "subtitle",
          "priceCents",
          "level",
          "coverUrl",
          "specialty",
          "instructor",
          "description",
          "modules"
        ]
      },
      "EnrolledCourse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "coverUrl": {
            "type": [
              "string",
              "null"
            ]
          },
          "specialty": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "slug": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "progress": {
            "type": "object",
            "properties": {
              "completed": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              },
              "pct": {
                "type": "integer"
              }
            },
            "required": [
              "completed",
              "total",
              "pct"
            ]
          }
        },
        "required": [
          "id",
          "slug",
          "title",
          "coverUrl",
          "specialty",
          "progress"
        ]
      },
      "CoursePlayer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": [
              "string",
              "null"
            ]
          },
          "modules": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "title": {
                  "type": "string"
                },
                "position": {
                  "type": "integer"
                },
                "lessons": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "title": {
                        "type": "string"
                      },
                      "durationSeconds": {
                        "type": "integer"
                      },
                      "vimeoVideoId": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "completed": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "id",
                      "title",
                      "durationSeconds",
                      "vimeoVideoId",
                      "completed"
                    ]
                  }
                }
              },
              "required": [
                "id",
                "title",
                "position",
                "lessons"
              ]
            }
          }
        },
        "required": [
          "id",
          "slug",
          "title",
          "subtitle",
          "modules"
        ]
      },
      "SecretariaRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "type": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "body": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "in_progress",
              "resolved"
            ]
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "type",
          "subject",
          "body",
          "status",
          "createdAt"
        ]
      },
      "CreateSecretariaInput": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60
          },
          "subject": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "body": {
            "type": "string",
            "maxLength": 4000
          }
        },
        "required": [
          "type",
          "subject"
        ]
      },
      "CreateLeadInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string",
            "maxLength": 40
          },
          "source": {
            "type": "string",
            "maxLength": 40
          }
        },
        "required": [
          "name",
          "email"
        ]
      },
      "Lead": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": [
              "string",
              "null"
            ]
          },
          "source": {
            "type": "string"
          },
          "stage": {
            "type": "string",
            "enum": [
              "new",
              "contacted",
              "qualified",
              "won",
              "lost"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "phone",
          "source",
          "stage",
          "notes",
          "createdAt"
        ]
      },
      "Kpis": {
        "type": "object",
        "properties": {
          "students": {
            "type": "integer"
          },
          "activeEnrollments": {
            "type": "integer"
          },
          "publishedCourses": {
            "type": "integer"
          },
          "completionRate": {
            "type": "number"
          },
          "estimatedRevenueCents": {
            "type": "integer"
          },
          "leadsByStage": {
            "type": "object",
            "properties": {
              "new": {
                "type": "integer"
              },
              "contacted": {
                "type": "integer"
              },
              "qualified": {
                "type": "integer"
              },
              "won": {
                "type": "integer"
              },
              "lost": {
                "type": "integer"
              }
            },
            "required": [
              "new",
              "contacted",
              "qualified",
              "won",
              "lost"
            ]
          }
        },
        "required": [
          "students",
          "activeEnrollments",
          "publishedCourses",
          "completionRate",
          "estimatedRevenueCents",
          "leadsByStage"
        ]
      },
      "AdminCourse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "published"
            ]
          },
          "level": {
            "type": "string",
            "enum": [
              "iniciante",
              "intermediario",
              "avancado"
            ]
          },
          "priceCents": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "slug",
          "title",
          "status",
          "level",
          "priceCents",
          "createdAt"
        ]
      },
      "Student": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          },
          "email": {
            "type": "string"
          },
          "enrollments": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "enrollments",
          "createdAt"
        ]
      },
      "UpdateCourseInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "subtitle": {
            "type": "string",
            "maxLength": 300
          },
          "description": {
            "type": "string",
            "maxLength": 8000
          },
          "priceCents": {
            "type": "integer",
            "minimum": 0
          },
          "level": {
            "type": "string",
            "enum": [
              "iniciante",
              "intermediario",
              "avancado"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "published"
            ]
          }
        }
      },
      "UpdateLeadInput": {
        "type": "object",
        "properties": {
          "stage": {
            "type": "string",
            "enum": [
              "new",
              "contacted",
              "qualified",
              "won",
              "lost"
            ]
          },
          "notes": {
            "type": "string",
            "maxLength": 4000
          }
        }
      }
