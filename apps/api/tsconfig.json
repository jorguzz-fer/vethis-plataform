{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "types": ["node"]
  },
  "include": ["src/**/*", "test/**/*", "drizzle.config.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"]
}
